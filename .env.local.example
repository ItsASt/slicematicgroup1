# Supabase — copy to .env.local and fill in from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose with NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=
# Server-only. Vercel Cron sends this as a Bearer token to protect the
# weekly feedback-insights refresh. Generate any long random string.
CRON_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
